# Shadcnblocks / Studio (optional vendor CLI)
# Shadcnblocks Pro account email
SHADCNBLOCKS_EMAIL=
# Optional label for the API key (matches the "Key Name" shown in Shadcnblocks dashboard)
SHADCNBLOCKS_API_KEY_NAME=
# Required for @shadcnblocks private registry. Create at https://www.shadcnblocks.com/account
SHADCNBLOCKS_API_KEY=
# Shadcn Studio Pro account email (vendor script copies this to EMAIL for the Studio CLI)
SHADCNSTUDIO_EMAIL=
# Shadcn Studio license key (vendor script copies this to LICENSE_KEY)
SHADCNSTUDIO_LICENSE_KEY=

# Resend contact route
# Create at https://resend.com > API Keys
RESEND_API_KEY=
# Inbox that receives contact-form submissions
CONTACT_TO_EMAIL=
# Verified Resend sending address. Domain must be verified in Resend before sending.
# Plain email or "Display Name <noreply@yourdomain.com>" both work.
CONTACT_FROM_EMAIL=

# Cloudflare deployment (for `pnpm run deploy` via OpenNext + Wrangler)
# https://dash.cloudflare.com -> right sidebar "Account ID"
CLOUDFLARE_ACCOUNT_ID=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# https://dash.cloudflare.com/profile/api-tokens (use the "Edit Cloudflare Workers" template).
# Optional if you've already run `pnpm dlx wrangler login` interactively on this machine.
CLOUDFLARE_API_TOKEN=

# Site identity
# Production canonical URL, no trailing slash (e.g. https://www.clientdomain.com).
# Used by sitemap.xml, robots.txt, canonical tags, and OG image base URL when those land.
NEXT_PUBLIC_SITE_URL=

# OpenNext / Wrangler local preview (optional)
NEXTJS_ENV=development

# Lighthouse CLI (optional override)
LIGHTHOUSE_URL=http://127.0.0.1:3000

# stitch.withgoogle.com api key for claude MCP test
STITCH_WITHGOOGLE_API_KEY=

# Stripe - test
STRIPE_TEST_PUBLISHABLE_KEY=
STRIPE_TEST_SECRET_KEY=

# Stripe
STRIPE_LIVE_PUBLISHABLE_KEY=
STRIPE_LIVE_SECRET_KEY=

# Stripe webhooks — STRIPE_WEBHOOK_SECRET is the TEST-mode signing secret;
# STRIPE_LIVE_WEBHOOK_SECRET is created at launch (the live endpoint).
STRIPE_WEBHOOK_SECRET=
STRIPE_LIVE_WEBHOOK_SECRET=

# Optional: force Stripe mode ("test" | "live"). Unset -> inferred from NODE_ENV
# (production -> live, otherwise test). Read by lib/stripe/server.ts.
STRIPE_MODE=

# Cloudflare Turnstile (contact-form CAPTCHA). Create keys in the Cloudflare
# dashboard > Turnstile (no Google account needed). Site key is build-time/public;
# secret is a server secret. Dev test keys (always pass): site 1x00000000000000000000AA,
# secret 1x0000000000000000000000000000000AA.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=